# IEEE Report Restructurer - Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# REQUIRED: Groq API Configuration
# ===========================================
# Get your API key from https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# LLM Model (default: llama-3.1-8b-instant)
# Options: llama-3.1-8b-instant, llama-3.2-90b-text-preview, mixtral-8x7b-32768
GROQ_MODEL=llama-3.1-8b-instant

# ===========================================
# File Upload Settings
# ===========================================
MAX_UPLOAD_SIZE_MB=50
UPLOAD_DIR=uploads
OUTPUT_DIR=outputs

# ===========================================
# Word Count Thresholds (IEEE Standard)
# ===========================================
MIN_SECTION_WORDS=200
MAX_SECTION_WORDS=400

# ===========================================
# LLM Processing Settings
# ===========================================
MAX_RETRIES=3
RETRY_DELAY_SECONDS=1.0
MAX_CONCURRENT_LLM_CALLS=5

# ===========================================
# CORS Settings
# ===========================================
# Comma-separated list of allowed origins
CORS_ORIGINS=["*"]
