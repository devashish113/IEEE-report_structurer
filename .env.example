# IEEE Report Restructurer - Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# REQUIRED: Groq API Configuration
# ===========================================
# Get your API key from: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# LLM Model (default: llama-3.1-8b-instant)
# Options: llama-3.1-8b-instant, llama-3.1-70b-versatile, mixtral-8x7b-32768
GROQ_MODEL=llama-3.1-8b-instant

# ===========================================
# Application Settings
# ===========================================
# Maximum upload file size in MB
MAX_UPLOAD_SIZE_MB=50

# Word count thresholds for section length control
MIN_SECTION_WORDS=250
MAX_SECTION_WORDS=600
TARGET_SECTION_WORDS=400

# ===========================================
# Server Settings
# ===========================================
# CORS allowed origins (comma-separated)
CORS_ORIGINS=*

# Directory paths (relative to backend)
UPLOAD_DIR=uploads
OUTPUT_DIR=outputs

# ===========================================
# Docker/Production Settings
# ===========================================
# Change these for production deployment
# REGISTRY=your-docker-registry.com
# DOCKER_TAG=latest
