# Docker ignore file for IEEE Report Restructurer

# Git
.git
.gitignore

# Python
__pycache__
*.py[cod]
*$py.class
*.so
.Python
*.egg-info
.eggs
*.egg
.pytest_cache
.mypy_cache
.ruff_cache

# Virtual environments
venv
.venv
env
.env.local

# IDE
.idea
.vscode
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Build artifacts
dist
build

# Test and coverage
htmlcov
.coverage
.tox
.nox

# Logs
*.log
logs

# Local data (mounted as volumes)
data/
backend/uploads/*
backend/outputs/*
!backend/uploads/.gitkeep
!backend/outputs/.gitkeep

# Documentation
docs/_build

# Temporary files
*.tmp
*.temp
*.bak

# Node modules (if any)
node_modules

# Jupyter
.ipynb_checkpoints
